{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "baseUrl": ".",
    "paths": {
      "@sayso/contracts": [
        "../sayso_web/packages/contracts/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../sayso_web/packages/contracts/src/**/*.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
